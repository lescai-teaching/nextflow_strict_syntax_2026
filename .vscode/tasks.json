{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve workshop docs",
      "type": "shell",
      "command": "/opt/conda/bin/mkdocs serve -a 0.0.0.0",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "Stop workshop docs",
      "type": "shell",
      "command": "pkill -f mkdocs",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": []
    }
  ]
}
