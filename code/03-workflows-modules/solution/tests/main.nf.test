nextflow_pipeline {

    name "Workflow module migration solution"
    script "../main.nf"
    config "../nextflow.config"

    tag "workflow_modules"

    test("runs migrated include pattern") {

        options "-profile test"

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.tasks().size() == 3 }
            )
        }
    }
}
