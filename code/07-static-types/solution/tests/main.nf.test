nextflow_pipeline {

    name "Static typing and records"
    script "../main.nf"
    config "../nextflow.config"

    tag "static_types"

    test("runs typed records") {

        options "-profile test"

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.tasks().size() == 2 }
            )
        }
    }
}
