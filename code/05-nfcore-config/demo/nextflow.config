plugins {
    id 'nf-schema@2.7.2'
}

params {
    cohort_size = 'panel'
    cohort_label = params.cohort_size == 'wgs' ? 'wgs' : 'panel'
    cohort_scratch = "/tmp/${System.getenv('USER') ?: 'user'}"
    cohort_queue = {
        if (params.cohort_size == 'wgs') {
            return 'long'
        } else {
            return 'short'
        }
    }.call()
}

validation {
    ignoreParams = [
        'cohort_size',
        'cohort_label',
        'cohort_scratch',
        'cohort_queue'
    ]
}

profiles {
    test {
        process {
            executor = 'local'
        }
    }
}
