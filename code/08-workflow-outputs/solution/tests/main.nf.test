nextflow_pipeline {

    name "Topic channels and workflow outputs"
    script "../main.nf"
    config "../nextflow.config"

    tag "workflow_outputs"

    test("runs topics and workflow output publishing") {

        options "-profile test"

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.tasks().size() == 4 }
            )
        }
    }
}
