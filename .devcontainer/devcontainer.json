{
    "name": "nextflow-strict-syntax-workshop",
    "image": "ghcr.io/nextflow-io/training:latest",
    "workspaceFolder": "/workspaces/nextflow_strict_syntax_2026",
    "remoteUser": "root",
    "remoteEnv": {
        "NXF_HOME": "/workspaces/.nextflow",
        "NXF_EDGE": "0",
        "NXF_VER": "26.04.1",
        "HOST_PROJECT_PATH": "/workspaces/nextflow_strict_syntax_2026",
        "SHELL": "/bin/bash"
    },
    "containerEnv": {
        "DOCKER_API_VERSION": "1.43"
    },
    "onCreateCommand": "bash .devcontainer/setup.sh",
    "postStartCommand": {
        "serve-docs": "python -m mkdocs serve --dev-addr 0.0.0.0:8000 > /tmp/mkdocs.log 2>&1"
    },
    "forwardPorts": [
        8000
    ],
    "portsAttributes": {
        "8000": {
            "label": "MkDocs site",
            "onAutoForward": "openPreview",
            "protocol": "http",
            "visibility": "public"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "nf-core.nf-core-extensionpack",
                "ms-vscode.live-server"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/conda/bin/python",
                "terminal.integrated.defaultProfile.linux": "bash",
                "workbench.startupEditor": "none"
            }
        }
    }
}
